# Copy to .dev.vars (gitignored) for local `wrangler dev` testing against a
# real Firebase project. NOT used by the automated test suite (vitest.config.js
# injects its own throwaway test service account/private key instead).
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"your-project","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com",...}
